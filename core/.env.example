# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# LiveKit (matches deploy/docker-compose.livekit.yml dev defaults)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret1234567890123456789012345678

# ── LLM ──────────────────────────────────────────────────────────────────────
# Pick one provider and set the matching key.
LLM_PROVIDER=openai          # openai | anthropic | mistral | groq | openrouter | together | perplexity
LLM_MODEL=gpt-4o             # any model name the provider accepts

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=

# For any other OpenAI-compatible provider, keep LLM_PROVIDER=openai and set:
# LLM_BASE_URL=https://your-provider/v1

# ── TTS ──────────────────────────────────────────────────────────────────────
TTS_PROVIDER=openai          # openai | deepgram | elevenlabs
# DEEPGRAM_TTS_MODEL=aura-2-andromeda-en
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=Rachel

# ── STT ──────────────────────────────────────────────────────────────────────
STT_PROVIDER=openai          # openai | deepgram
# DEEPGRAM_API_KEY=          # also used for TTS when TTS_PROVIDER=deepgram

# ── Embeddings ───────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER=local   # local = sentence-transformers (no API key needed)
